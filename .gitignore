# Large downloaded app packages
*.ipa
*.ipa.tmp
*.apk
*.apks
discord-ipas/*.ipa
discord-ipas/*.ipa.tmp
ipas/**/*.ipa
ipas/**/*.ipa.tmp
apks/**/*.apk
apks/**/*.apks

# Python/runtime noise
__pycache__/
*.py[cod]

# Local transient logs/caches
.DS_Store
*.tmp
tmp/
cache/

# Durable task logs
!logs/
!logs/run.log
!logs/deleted-ipas.log
